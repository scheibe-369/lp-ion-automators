---
import SectionHeadline from './SectionHeadline.astro';
---

<section id="instrutores" class="py-24 lg:py-32 scroll-mt-20">
	<div class="max-w-[1200px] mx-auto px-6 lg:px-8">
		<SectionHeadline
			badge="QUEM VAI TE GUIAR"
			title="Aprenda com quem <span class='text-primary-light'>faz na prática</span>"
			subtitle="Profissionais com experiência real em IA aplicada a vendas e automação em produção."
		/>

		<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" data-animate="fade-in-up">
			<!-- Helio - Principal -->
			<div class="md:col-span-2 lg:col-span-1 glass-card border-primary/50 shadow-[0_0_30px_rgba(124,58,237,0.1)] rounded-2xl p-8 relative overflow-hidden">
				<div class="absolute top-0 right-0 w-32 h-32 bg-primary/5 rounded-full -translate-y-1/2 translate-x-1/2"></div>
				<div class="relative">
					<div class="w-20 h-20 rounded-full bg-gradient-to-br from-primary to-[#9333EA] flex items-center justify-center mb-5">
						<span class="text-3xl font-display font-bold text-white">H</span>
					</div>
					<h3 class="text-xl font-semibold text-white mb-1">Helio</h3>
					<p class="text-primary-light text-sm font-medium mb-4">Fundador da Growth Hub</p>
					<!-- PLACEHOLDER: Substituir com bio real -->
					<p class="text-text-muted leading-relaxed text-sm">Especialista em IA aplicada a processos comerciais e automação. Já ajudou centenas de profissionais a escalar resultados usando tecnologia na prática.</p>
				</div>
			</div>

			<!-- Equipe placeholder 1 -->
			<div class="glass-card rounded-2xl p-8">
				<div class="w-20 h-20 rounded-full bg-surface-alt flex items-center justify-center mb-5">
					<svg class="w-8 h-8 text-text-muted" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
				</div>
				<h3 class="text-xl font-semibold text-white mb-1">Instrutor(a) 2</h3>
				<p class="text-text-muted text-sm font-medium mb-4">Especialidade</p>
				<!-- PLACEHOLDER: Substituir com conteúdo real -->
				<p class="text-text-muted leading-relaxed text-sm">Bio do instrutor. Experiência e especialidade na área de automação e IA comercial.</p>
			</div>

			<!-- Equipe placeholder 2 -->
			<div class="glass-card rounded-2xl p-8">
				<div class="w-20 h-20 rounded-full bg-surface-alt flex items-center justify-center mb-5">
					<svg class="w-8 h-8 text-text-muted" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
				</div>
				<h3 class="text-xl font-semibold text-white mb-1">Instrutor(a) 3</h3>
				<p class="text-text-muted text-sm font-medium mb-4">Especialidade</p>
				<!-- PLACEHOLDER: Substituir com conteúdo real -->
				<p class="text-text-muted leading-relaxed text-sm">Bio do instrutor. Experiência e especialidade na área de automação e IA comercial.</p>
			</div>
		</div>
	</div>
</section>
