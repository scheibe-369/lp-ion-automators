---
import SectionHeadline from '../SectionHeadline.astro';

const problems = [
	{
		icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m15 9-6 6"/><path d="m9 9 6 6"/></svg>`,
		title: 'Ferramentas dispersas',
		description: 'Aplicações que não conversam, exigindo trabalho manual infinito.',
	},
	{
		icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10 10h4"/><path d="M19 7V4a1 1 0 0 0-1-1H5a2 2 0 0 0 0 4h15a1 1 0 0 1 1 1v4h-3a2 2 0 0 0 0 4h3a1 1 0 0 0 1-1v-2.5"/><path d="M3 5v14a2 2 0 0 0 2 2h15a1 1 0 0 0 1-1v-4"/></svg>`,
		title: 'Perda de Vendas',
		description: 'Leads esfriam por falta de follow-up automatizado e processo.',
	},
];

const forYou = [
	'Gestores e Vendedores buscando automação e IA',
	'Empreendedores que precisam escalar',
	'Agências que vendem automação (n8n)',
	'Gestores de tráfego vendo essa necessidade',
	'Quem quer criar seu primeiro SaaS ou sistema',
];
---

<section id="transformacao" class="py-24 lg:py-32 scroll-mt-32 relative overflow-hidden">
	<!-- Glow de fundo -->
	<div class="absolute top-0 right-0 w-[500px] h-[500px] bg-primary/10 rounded-full blur-[100px] pointer-events-none"></div>
	<div class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-error/5 rounded-full blur-[100px] pointer-events-none"></div>

	<div class="max-w-[1200px] mx-auto px-6 lg:px-8 relative z-10">
		<div class="text-center mb-16" data-animate="fade-in-up">
			<h2 class="text-3xl md:text-5xl font-display font-bold text-white leading-tight mb-4">
				Duas Comunidades Completas <br/>
				<span class="text-transparent bg-clip-text bg-gradient-to-r from-primary-light to-primary">Conhecimento em Dobro</span>
			</h2>
		</div>

		<!-- Cards grid -->
		<div class="grid grid-cols-1 sm:grid-cols-2 gap-6" data-animate="fade-in-up">

				<!-- ION Card -->
				<div class="glass-item" id="card-ion">
					<!-- Floating bubbles -->
					<div class="bubble-container">
						<div class="bubble bubble-1"></div>
						<div class="bubble bubble-2"></div>
					</div>
					<!-- Specular shine (follows mouse) -->
					<div class="specular-shine"></div>
					<!-- Rim light -->
					<div class="rim-light"></div>
					<!-- Content -->
					<div class="card-content">
						<div class="logo-box">
							<img src="/logos/logo-ion.svg" alt="ION Academy Logo" class="logo-img" />
						</div>
						<h4 class="card-title">ION Academy</h4>
						<p class="card-desc">Domine a IA aplicada a negociações, scripts hiper-personalizados e criação da máquina de qualificação comercial.</p>
						<div class="divider"></div>
						<ul class="card-list">
							<li>✔ Escalando Agência de IA</li>
							<li>✔ Formas de fazer dinheiro com IA</li>
							<li>✔ Contratando time</li>
							<li>✔ Review de TODAS as LLM'S</li>
							<li>✔ Vibe Coding</li>
						</ul>
					</div>
				</div>

				<!-- AUTOMATORS Card -->
				<div class="glass-item" id="card-automators">
					<!-- Floating bubbles -->
					<div class="bubble-container">
						<div class="bubble bubble-1"></div>
						<div class="bubble bubble-2"></div>
					</div>
					<!-- Specular shine (follows mouse) -->
					<div class="specular-shine"></div>
					<!-- Rim light -->
					<div class="rim-light"></div>
					<!-- Content -->
					<div class="card-content">
						<div class="logo-box">
							<img src="/logos/logo-automators.svg" alt="Automators Club Logo" class="logo-img" />
						</div>
						<h4 class="card-title">Automators Club</h4>
						<p class="card-desc">Coloque o n8n em produção. Crie workflows reais com WhatsApp, CRMs e Emails 100% no automático.</p>
						<div class="divider"></div>
						<ul class="card-list">
							<li>✔ API Oficial</li>
							<li>✔ N8N Avançado</li>
							<li>✔ Automações para negócios</li>
							<li>✔ Formas de fazer dinheiro com IA</li>
							<li>✔ Vibe Coding</li>
						</ul>
					</div>
				</div>

		</div>
	</div>
</section>

<style>
	/* ── Glass Card ──────────────────────────────────────────────────── */
	.glass-item {
		position: relative;
		min-height: 420px;
		display: flex;
		flex-direction: column;
		overflow: hidden;
		border-radius: 2rem;
		background: rgb(8, 8, 8);
		transition: transform 0.7s cubic-bezier(0.23, 1, 0.32, 1),
		            box-shadow 0.7s cubic-bezier(0.23, 1, 0.32, 1);
	}

	/* Rotating neon border */
	.glass-item::before {
		content: "";
		position: absolute;
		top: -50%;
		left: -50%;
		width: 200%;
		height: 200%;
		background: conic-gradient(
			from 0deg,
			transparent 0%,
			transparent 70%,
			rgba(188, 133, 255, 0.4) 92%,
			rgba(168, 85, 247, 0.6) 96%,
			rgba(188, 133, 255, 0.4) 99%,
			transparent 100%
		);
		animation: borderRotate 15s linear infinite;
		z-index: 1;
		filter: blur(25px);
		opacity: 0.8;
	}

	/* Inner mask — creates the dark card bg */
	.glass-item::after {
		content: "";
		position: absolute;
		inset: 1.5px;
		background: rgba(8, 8, 8, 0.92);
		border-radius: calc(2rem - 1.5px);
		z-index: 2;
		backdrop-filter: blur(40px) saturate(140%);
		-webkit-backdrop-filter: blur(40px) saturate(140%);
	}

	@keyframes borderRotate {
		from { transform: rotate(0deg); }
		to   { transform: rotate(360deg); }
	}

	/* Hover */
	.glass-item:hover {
		transform: translateY(-8px) scale(1.01);
		box-shadow: 0 30px 60px -10px rgba(0, 0, 0, 0.5);
	}

	.glass-item:hover .logo-box {
		border-color: rgba(168, 85, 247, 0.35);
		box-shadow: 0 0 28px rgba(168, 85, 247, 0.2);
		transform: scale(1.05) rotate(-2deg);
	}

	/* ── Bubbles ─────────────────────────────────────────────────────── */
	.bubble-container {
		position: absolute;
		inset: 0;
		z-index: 3;
		overflow: hidden;
		border-radius: 2rem;
		pointer-events: none;
	}

	.bubble {
		position: absolute;
		border-radius: 50%;
		opacity: 0.3;
		filter: blur(10px);
	}

	.bubble-1 {
		width: 180px;
		height: 180px;
		top: -40px;
		right: -20px;
		background: radial-gradient(130% 130% at 30% 30%, rgba(255,255,255,0.08) 10%, rgba(255,255,255,0.01) 100%);
		box-shadow: inset 2px 2px 5px rgba(255,255,255,0.05), inset -2px -2px 5px rgba(0,0,0,0.5);
		animation: floatBubble1 12s infinite ease-in-out;
	}

	.bubble-2 {
		width: 120px;
		height: 120px;
		bottom: 20px;
		left: -30px;
		background: radial-gradient(130% 130% at 70% 70%, rgba(168,85,247,0.12) 0%, rgba(0,0,0,0) 100%);
		box-shadow: inset 2px 2px 5px rgba(255,255,255,0.05), inset -2px -2px 5px rgba(0,0,0,0.5);
		animation: floatBubble2 9s infinite ease-in-out reverse;
	}

	@keyframes floatBubble1 {
		0%, 100% { transform: translate(0, 0) scale(1); }
		50%       { transform: translate(-20px, 30px) scale(1.05); }
	}

	@keyframes floatBubble2 {
		0%, 100% { transform: translate(0, 0) scale(1); }
		50%       { transform: translate(30px, -20px) scale(0.95); }
	}

	/* ── Specular shine (mouse spotlight) ───────────────────────────── */
	.specular-shine {
		position: absolute;
		inset: 0;
		z-index: 5;
		opacity: 0;
		pointer-events: none;
		transition: opacity 1s;
		border-radius: 2rem;
		background: radial-gradient(
			circle at var(--mouse-x, 50%) var(--mouse-y, 50%),
			rgba(255,255,255,0.07) 0%,
			transparent 60%
		);
	}

	.glass-item:hover .specular-shine {
		opacity: 1;
	}

	/* ── Rim light ───────────────────────────────────────────────────── */
	.rim-light {
		position: absolute;
		inset: 2px;
		z-index: 3;
		border-radius: calc(2rem - 2px);
		opacity: 0.5;
		pointer-events: none;
		background: linear-gradient(135deg, rgba(255,255,255,0.08) 0%, transparent 40%);
	}

	/* ── Card content ────────────────────────────────────────────────── */
	.card-content {
		position: relative;
		z-index: 4;
		display: flex;
		flex-direction: column;
		height: 100%;
		padding: 2rem;
		background: linear-gradient(160deg, rgba(255,255,255,0.01) 0%, rgba(0,0,0,0.2) 100%);
	}

	.logo-box {
		height: 6rem;
		margin-bottom: 1.5rem;
		display: flex;
		align-items: center;
		justify-content: flex-start;
		border: 1px solid rgba(255,255,255,0.05);
		background: rgba(255,255,255,0.03);
		border-radius: 1rem;
		padding: 0.75rem 1.25rem;
		transition: all 0.7s cubic-bezier(0.23, 1, 0.32, 1);
	}

	.logo-img {
		height: 140%;
		width: auto;
		object-fit: contain;
	}

	.card-title {
		font-size: 1.125rem;
		font-weight: 700;
		color: #ffffff;
		margin-bottom: 0.5rem;
		transition: color 0.5s;
	}

	.glass-item:hover .card-title {
		color: #c4b5fd;
	}

	.card-desc {
		font-size: 0.875rem;
		color: rgba(161,161,170,0.9);
		line-height: 1.6;
		margin-bottom: 1rem;
	}

	.divider {
		height: 1px;
		background: rgba(255,255,255,0.05);
		margin-bottom: 1rem;
	}

	.card-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.card-list li {
		font-size: 0.75rem;
		color: rgba(161,161,170,0.85);
	}
</style>

<script>
	document.querySelectorAll('.glass-item').forEach((card) => {
		card.addEventListener('mousemove', (e) => {
			const el = e.currentTarget as HTMLElement;
			const rect = el.getBoundingClientRect();
			const x = (e as MouseEvent).clientX - rect.left;
			const y = (e as MouseEvent).clientY - rect.top;
			el.style.setProperty('--mouse-x', `${x}px`);
			el.style.setProperty('--mouse-y', `${y}px`);
		});
	});
</script>
