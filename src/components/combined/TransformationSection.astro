---
import SectionHeadline from '../SectionHeadline.astro';

const problems = [
	{
		icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m15 9-6 6"/><path d="m9 9 6 6"/></svg>`,
		title: 'Ferramentas dispersas',
		description: 'Aplicações que não conversam, exigindo trabalho manual infinito.',
	},
	{
		icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10 10h4"/><path d="M19 7V4a1 1 0 0 0-1-1H5a2 2 0 0 0 0 4h15a1 1 0 0 1 1 1v4h-3a2 2 0 0 0 0 4h3a1 1 0 0 0 1-1v-2.5"/><path d="M3 5v14a2 2 0 0 0 2 2h15a1 1 0 0 0 1-1v-4"/></svg>`,
		title: 'Perda de Vendas',
		description: 'Leads esfriam por falta de follow-up automatizado e processo.',
	},
];

const forYou = [
	'Gestores e Vendedores buscando automação e IA',
	'Empreendedores que precisam escalar',
	'Agências que vendem automação (n8n)',
	'Gestores de tráfego vendo essa necessidade',
	'Quem quer criar seu primeiro SaaS ou sistema',
];

---

<section id="transformacao" class="py-20 lg:py-32 scroll-mt-32 relative overflow-hidden">
	<!-- Glow de fundo -->
	<div class="absolute top-0 right-0 w-[500px] h-[500px] bg-primary/10 rounded-full blur-[100px] pointer-events-none"></div>
	<div class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-error/5 rounded-full blur-[100px] pointer-events-none"></div>

	<div class="max-w-[1200px] mx-auto px-6 lg:px-8 relative z-10">
		<div class="text-center mb-16" data-animate="fade-in-up">
			<span class="inline-block py-1 px-3 rounded-full bg-surface-alt border border-white/5 text-xs text-text-muted font-semibold tracking-wider uppercase mb-4">
				A TRANSFORMAÇÃO
			</span>
			<h2 class="text-3xl md:text-5xl font-display font-bold text-white leading-tight mb-4">
				Do caos operacional para a <br/>
				<span class="text-transparent bg-clip-text bg-gradient-to-r from-primary-light to-primary">Máquina de Vendas Infinita</span>
			</h2>
		</div>

		<!-- Bento Box Grid -->
		<div class="grid grid-cols-1 lg:grid-cols-12 gap-6 lg:gap-8">
			
			<!-- Coluna Esquerda: A DOR E PERFIL (5 colunas no LG) -->
			<div class="lg:col-span-5 flex flex-col gap-6">
				<!-- Problemas -->
				<div class="glass-card rounded-2xl p-8 border border-error/20 bg-gradient-to-br from-surface to-error/5 relative overflow-hidden" data-animate="slide-in-left">
					<div class="absolute top-0 left-0 w-2 h-full bg-error/50"></div>
					<h3 class="text-xl font-bold text-white mb-6 flex items-center gap-2">
						<span class="text-error">O Problema Atual</span>
					</h3>
					<div class="flex flex-col gap-5">
						{problems.map(p => (
							<div class="flex gap-4">
								<div class="w-10 h-10 shrink-0 rounded-lg bg-error/10 text-error flex items-center justify-center">
									<Fragment set:html={p.icon} />
								</div>
								<div>
									<h4 class="text-white font-medium mb-1">{p.title}</h4>
									<p class="text-sm text-text-muted leading-relaxed">{p.description}</p>
								</div>
							</div>
						))}
					</div>
				</div>

				<!-- Para Quem -->
				<div class="glass-card rounded-2xl p-6 border border-white/10" data-animate="fade-in-up">
					<h3 class="text-sm font-bold text-white uppercase tracking-wider mb-4 border-b border-white/10 pb-2">Pra quem é essa solução?</h3>
					<ul class="space-y-3">
						{forYou.map(item => (
							<li class="flex items-start gap-3">
								<svg class="w-4 h-4 text-success mt-0.5 shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
								<span class="text-sm text-text-muted">{item}</span>
							</li>
						))}
					</ul>
				</div>
			</div>

			<!-- Coluna Direita: A SOLUÇÃO BUNDLE (7 colunas no LG) -->
			<div class="lg:col-span-7 flex flex-col gap-6">
				
				<div class="glass-card rounded-2xl p-8 lg:p-10 border border-primary/30 bg-gradient-to-br from-surface to-primary/10 h-full flex flex-col justify-center relative overflow-hidden" data-animate="slide-in-right">
					<!-- Decoração -->
					<div class="absolute top-0 right-0 w-64 h-64 bg-primary/20 rounded-full blur-[80px]"></div>
					
					<div class="relative z-10">
						<div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-primary/20 border border-primary/30 text-primary-light text-xs font-semibold mb-6">
							<span class="w-2 h-2 rounded-full bg-primary-light animate-pulse"></span>
							O Bundle Definitivo
						</div>
						
						<h3 class="text-2xl md:text-3xl font-display font-bold text-white mb-8">
							Dois programas completos.<br/>
							O poder duplo da automação.
						</h3>

						<div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
							<!-- ION -->
							<div class="bg-background/50 rounded-xl p-5 border border-white/5 hover:border-primary/50 transition-colors">
								<div class="h-20 mb-6 flex items-center justify-start">
									<img src="/logos/logo-ion.svg" alt="Treinamento ION Logo" class="h-full w-auto object-contain" />
								</div>
								<h4 class="text-lg font-bold text-white mb-2">Treinamento ION</h4>
								<p class="text-sm text-text-muted mb-4">Domine a IA aplicada a negociações, scripts hiper-personalizados e criação da máquina de qualificação comercial.</p>
								<ul class="text-xs text-text-muted space-y-2">
									<li class="flex gap-2">✔ Escalando Agência de IA</li>
									<li class="flex gap-2">✔ Formas de fazer dinheiro com IA</li>
									<li class="flex gap-2">✔ Contratando time</li>
									<li class="flex gap-2">✔ Review de TODAS as LLM'S</li>
									<li class="flex gap-2">✔ Vibe Coding</li>
								</ul>
							</div>

							<!-- AUTOMATORS -->
							<div class="bg-background/50 rounded-xl p-5 border border-white/5 hover:border-success/50 transition-colors">
								<div class="h-20 mb-6 flex items-center justify-start">
									<img src="/logos/logo-automators.svg" alt="Automators Club Logo" class="h-full w-auto object-contain" />
								</div>
								<h4 class="text-lg font-bold text-white mb-2">Automators Club</h4>
								<p class="text-sm text-text-muted mb-4">Coloque o n8n em produção. Crie workflows reais com WhatsApp, CRMs e Emails 100% no automático.</p>
								<ul class="text-xs text-text-muted space-y-2">
									<li class="flex gap-2">✔ API Oficial</li>
									<li class="flex gap-2">✔ N8N Avançado</li>
									<li class="flex gap-2">✔ Automações para negócios</li>
									<li class="flex gap-2">✔ Formas de fazer dinheiro com IA</li>
									<li class="flex gap-2">✔ Vibe Coding</li>
								</ul>
							</div>
						</div>
					</div>
				</div>

			</div>
		</div>
	</div>
</section>
