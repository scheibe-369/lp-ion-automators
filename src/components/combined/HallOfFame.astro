---
import SectionHeadline from '../SectionHeadline.astro';

const cases = [
	'/depoimentos/IMG_3580.PNG',
	'/depoimentos/IMG_6951.PNG',
	'/depoimentos/IMG_6955.PNG',
	'/depoimentos/IMG_6957.PNG',
	'/depoimentos/IMG_6985.PNG',
	'/depoimentos/IMG_8151.PNG',
];
---

<section id="professores-e-alunos" class="py-24 lg:py-32 scroll-mt-32 relative overflow-hidden bg-background">
	<!-- Background Effects -->
	<div class="absolute top-[20%] left-[-10%] w-[500px] h-[500px] bg-primary/10 rounded-full blur-[120px] pointer-events-none"></div>

	<div class="max-w-[1200px] mx-auto px-6 lg:px-8 relative z-10">
		
		<div class="text-center mb-16" data-animate="fade-in-up">
			<h2 class="text-3xl md:text-5xl font-display font-bold text-white leading-tight">
				Aprenda com os Melhores.<br/>
				Torne-se um <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary-light to-primary">Deles.</span>
			</h2>
		</div>

		<!-- Instructors -->
		<div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-32 lg:mb-48 relative" data-animate="fade-in-up" style="animation-delay: 100ms">

			<!-- Helio -->
			<div class="glass-instructor" id="card-helio">
				<div class="bubble-container">
					<div class="bubble bubble-1"></div>
					<div class="bubble bubble-2"></div>
				</div>
				<div class="specular-shine"></div>
				<div class="rim-light"></div>
				<div class="instr-content">
					<div class="photo-box photo-box--helio">
						<img src="/instructors/helio.png" alt="Helio" class="w-full h-full object-cover object-[center_35%] scale-[1.1]" />
					</div>
					<div class="instr-text">
						<h3 class="instr-name">Helio Monteiro</h3>
						<div class="instr-badge instr-badge--purple">Fundador da Ion</div>
						<p class="instr-bio">
							Especialista absoluto em IA aplicada a processos comerciais. Construiu a ponte perfeita entre a teoria da Inteligência Artificial e a prática das vendas automatizadas usando o n8n. Já ajudou centenas de profissionais a escalar resultados criando máquinas de vendas que operam 24/7.
						</p>
					</div>
				</div>
			</div>

			<!-- Matheus -->
			<div class="glass-instructor" id="card-matheus">
				<div class="bubble-container">
					<div class="bubble bubble-1"></div>
					<div class="bubble bubble-2"></div>
				</div>
				<div class="specular-shine"></div>
				<div class="rim-light"></div>
				<div class="instr-content">
					<div class="photo-box photo-box--matheus">
						<img src="/instructors/matheus.png" alt="Matheus Fonseca" class="w-full h-full object-cover object-[center_15%] scale-[1.4]" />
					</div>
					<div class="instr-text">
						<h3 class="instr-name">Matheus Fonseca</h3>
						<div class="instr-badge instr-badge--blue">Fundador do Automators Club</div>
						<p class="instr-bio">
							Referência em Inteligência Artificial aplicada a negócios. Já ajudou mais de 40 empresas a eliminar processos manuais e escalar resultados usando IA. Constrói sistemas que trabalham 24/7 para que as pessoas foquem no que realmente importa.
						</p>
					</div>
				</div>
			</div>

		</div>

	</div>

	<!-- Testimonials Marquee / Floating Bobbles -->
	<div class="max-w-[1200px] mx-auto px-6 lg:px-8 text-center mb-16 relative z-10" data-animate="fade-in-up">
		<h2 class="text-3xl md:text-5xl font-display font-bold text-white leading-tight">
			Os Resultados dos Nossos <br/>Alunos <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary-light to-primary">Já Dizem Tudo</span>
		</h2>
	</div>

	<div class="w-full overflow-hidden flex flex-col gap-6 py-4 relative" data-animate="fade-in-up" style="animation-delay: 200ms">
		
		<!-- Left Fade / Right Fade -->
		<div class="absolute inset-y-0 left-0 w-32 bg-gradient-to-r from-background to-transparent z-10 pointer-events-none"></div>
		<div class="absolute inset-y-0 right-0 w-32 bg-gradient-to-l from-background to-transparent z-10 pointer-events-none"></div>

		<!-- Linha 1 -->
		<div class="flex flex-nowrap shrink-0 animate-marquee gap-6 w-max">
			{cases.map(imgSrc => (
				<div class="w-[350px] shrink-0 rounded-2xl overflow-hidden border border-white/5 bg-surface/40 hover:border-white/20 transition-colors flex items-center justify-center p-2">
					<img src={imgSrc} alt="Depoimento de aluno" class="max-w-full h-auto object-contain rounded-xl" />
				</div>
			))}
			<!-- Duplicate for infinite scroll -->
			{cases.map(imgSrc => (
				<div class="w-[350px] shrink-0 rounded-2xl overflow-hidden border border-white/5 bg-surface/40 hover:border-white/20 transition-colors flex items-center justify-center p-2" aria-hidden="true">
					<img src={imgSrc} alt="Depoimento de aluno" class="max-w-full h-auto object-contain rounded-xl" />
				</div>
			))}
		</div>

	</div>
</section>

<style>
	/* ── Glass Instructor Card ───────────────────────────────────────── */
	.glass-instructor {
		position: relative;
		overflow: hidden;
		border-radius: 1.5rem;
		background: rgb(8, 8, 8);
		transition: transform 0.7s cubic-bezier(0.23, 1, 0.32, 1),
		            box-shadow 0.7s cubic-bezier(0.23, 1, 0.32, 1);
	}

	/* Rotating neon border */
	.glass-instructor::before {
		content: "";
		position: absolute;
		top: -50%;
		left: -50%;
		width: 200%;
		height: 200%;
		background: conic-gradient(
			from 0deg,
			transparent 0%,
			transparent 70%,
			rgba(188, 133, 255, 0.4) 92%,
			rgba(168, 85, 247, 0.6) 96%,
			rgba(188, 133, 255, 0.4) 99%,
			transparent 100%
		);
		animation: instrBorderRotate 15s linear infinite;
		z-index: 1;
		filter: blur(25px);
		opacity: 0.8;
	}

	/* Inner dark mask */
	.glass-instructor::after {
		content: "";
		position: absolute;
		inset: 1.5px;
		background: rgba(8, 8, 8, 0.92);
		border-radius: calc(1.5rem - 1.5px);
		z-index: 2;
		backdrop-filter: blur(40px) saturate(140%);
		-webkit-backdrop-filter: blur(40px) saturate(140%);
	}

	@keyframes instrBorderRotate {
		from { transform: rotate(0deg); }
		to   { transform: rotate(360deg); }
	}

	.glass-instructor:hover {
		transform: translateY(-8px) scale(1.01);
		box-shadow: 0 30px 60px -10px rgba(0, 0, 0, 0.5);
	}

	.glass-instructor:hover .photo-box {
		border-color: rgba(168, 85, 247, 0.4);
		box-shadow: 0 0 28px rgba(168, 85, 247, 0.25);
		transform: scale(1.05) rotate(-2deg);
	}

	.glass-instructor:hover .instr-name {
		color: #c4b5fd;
	}

	/* ── Bubbles ─────────────────────────────────────────────────────── */
	.bubble-container {
		position: absolute;
		inset: 0;
		z-index: 3;
		overflow: hidden;
		border-radius: 1.5rem;
		pointer-events: none;
	}

	.bubble {
		position: absolute;
		border-radius: 50%;
		opacity: 0.3;
		filter: blur(10px);
	}

	.bubble-1 {
		width: 180px;
		height: 180px;
		top: -40px;
		right: -20px;
		background: radial-gradient(130% 130% at 30% 30%, rgba(255,255,255,0.08) 10%, rgba(255,255,255,0.01) 100%);
		box-shadow: inset 2px 2px 5px rgba(255,255,255,0.05), inset -2px -2px 5px rgba(0,0,0,0.5);
		animation: instrFloat1 12s infinite ease-in-out;
	}

	.bubble-2 {
		width: 120px;
		height: 120px;
		bottom: 20px;
		left: -30px;
		background: radial-gradient(130% 130% at 70% 70%, rgba(168,85,247,0.12) 0%, rgba(0,0,0,0) 100%);
		box-shadow: inset 2px 2px 5px rgba(255,255,255,0.05), inset -2px -2px 5px rgba(0,0,0,0.5);
		animation: instrFloat2 9s infinite ease-in-out reverse;
	}

	@keyframes instrFloat1 {
		0%, 100% { transform: translate(0, 0) scale(1); }
		50%       { transform: translate(-20px, 30px) scale(1.05); }
	}

	@keyframes instrFloat2 {
		0%, 100% { transform: translate(0, 0) scale(1); }
		50%       { transform: translate(30px, -20px) scale(0.95); }
	}

	/* ── Specular shine ──────────────────────────────────────────────── */
	.specular-shine {
		position: absolute;
		inset: 0;
		z-index: 5;
		opacity: 0;
		pointer-events: none;
		transition: opacity 1s;
		border-radius: 1.5rem;
		background: radial-gradient(
			circle at var(--mouse-x, 50%) var(--mouse-y, 50%),
			rgba(255,255,255,0.07) 0%,
			transparent 60%
		);
	}

	.glass-instructor:hover .specular-shine {
		opacity: 1;
	}

	/* ── Rim light ───────────────────────────────────────────────────── */
	.rim-light {
		position: absolute;
		inset: 2px;
		z-index: 3;
		border-radius: calc(1.5rem - 2px);
		opacity: 0.5;
		pointer-events: none;
		background: linear-gradient(135deg, rgba(255,255,255,0.08) 0%, transparent 40%);
	}

	/* ── Card content ────────────────────────────────────────────────── */
	.instr-content {
		position: relative;
		z-index: 4;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1.5rem;
		padding: 2rem 2.5rem;
		background: linear-gradient(160deg, rgba(255,255,255,0.01) 0%, rgba(0,0,0,0.2) 100%);
	}

	@media (min-width: 640px) {
		.instr-content {
			flex-direction: row;
			align-items: flex-start;
		}
	}

	.photo-box {
		width: 6rem;
		height: 6rem;
		flex-shrink: 0;
		border-radius: 1rem;
		overflow: hidden;
		border: 1px solid rgba(255,255,255,0.1);
		transition: all 0.7s cubic-bezier(0.23, 1, 0.32, 1);
	}

	@media (min-width: 640px) {
		.photo-box {
			width: 7rem;
			height: 7rem;
		}
	}

	.photo-box--helio { background: #1c1c1e; }
	.photo-box--matheus { background: #000; }

	.instr-text {
		text-align: center;
		flex: 1;
	}

	@media (min-width: 640px) {
		.instr-text { text-align: left; }
	}

	.instr-name {
		font-size: 1.25rem;
		font-weight: 700;
		color: #ffffff;
		margin-bottom: 0.25rem;
		transition: color 0.5s;
	}

	@media (min-width: 1024px) {
		.instr-name { font-size: 1.5rem; }
	}

	.instr-badge {
		display: inline-flex;
		align-items: center;
		padding: 2px 12px;
		border-radius: 9999px;
		font-size: 0.625rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		margin-bottom: 1rem;
	}

	.instr-badge--purple {
		background: rgba(124, 58, 237, 0.2);
		color: #a78bfa;
	}

	.instr-badge--blue {
		background: rgba(14, 165, 233, 0.15);
		color: #7dd3fc;
		border: 1px solid rgba(14, 165, 233, 0.2);
	}

	.instr-bio {
		font-size: 0.875rem;
		color: #A1A1AA;
		line-height: 1.7;
	}
</style>

<script>
	document.querySelectorAll('.glass-instructor').forEach((card) => {
		card.addEventListener('mousemove', (e) => {
			const el = e.currentTarget as HTMLElement;
			const rect = el.getBoundingClientRect();
			const x = (e as MouseEvent).clientX - rect.left;
			const y = (e as MouseEvent).clientY - rect.top;
			el.style.setProperty('--mouse-x', `${x}px`);
			el.style.setProperty('--mouse-y', `${y}px`);
		});
	});
</script>
