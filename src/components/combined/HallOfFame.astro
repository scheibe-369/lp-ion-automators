---
import SectionHeadline from '../SectionHeadline.astro';

const cases = [
	{ before: 'Manuais infinitos', after: 'Lead scoring via n8n', text: '"Resultado em 2 semanas."', author: 'João (Gestor)' },
	{ before: 'Follow-ups perdidos', after: 'Disparo via WhatsApp', text: '"Nunca mais perdi vendas."', author: 'Maria (SDR)' },
	{ before: 'Relatórios lentos', after: 'Dashboard realtime', text: '"Economizo 8h por semana."', author: 'Pedro (Agência)' },
	{ name: 'Aluno 1', role: 'Gestor Comercial', text: '"O ION mudou completamente a forma como eu uso IA no meu processo de vendas."' },
	{ name: 'Aluno 2', role: 'Empreendedor', text: '"O Automators Club me tirou do zero no n8n. Hoje tenho 12 workflows rodando em produção sem precisar de desenvolvedor."' },
	{ name: 'Aluno 3', role: 'Consultor de Vendas', text: '"As calls ao vivo fazem toda a diferença. Poder trazer meu projeto real e receber feedback direto acelerou muito meu resultado."' },
];
---

<section id="professores-e-alunos" class="py-24 lg:py-32 scroll-mt-32 relative overflow-hidden bg-background">
	<!-- Background Effects -->
	<div class="absolute top-[20%] left-[-10%] w-[500px] h-[500px] bg-primary/10 rounded-full blur-[120px] pointer-events-none"></div>

	<div class="max-w-[1200px] mx-auto px-6 lg:px-8 relative z-10">
		
		<div class="text-center mb-16" data-animate="fade-in-up">
			<span class="inline-block py-1 px-3 rounded-full glass-card border-white/10 text-xs text-text-muted font-semibold tracking-wider uppercase mb-4">
				OS MESTRES E OS RESULTADOS
			</span>
			<h2 class="text-3xl md:text-5xl font-display font-bold text-white leading-tight">
				Aprenda com os melhores.<br/>
				Torne-se um <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary-light to-primary">deles.</span>
			</h2>
		</div>

		<!-- Instructors -->
		<div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-24 relative" data-animate="fade-in-up" style="animation-delay: 100ms">
			<!-- Helio - Main -->
			<div class="md:col-span-3 glass-card border border-primary/30 shadow-[0_0_40px_rgba(124,58,237,0.15)] rounded-2xl p-8 lg:p-12 relative overflow-hidden bg-gradient-to-br from-surface to-primary/5 flex flex-col md:flex-row items-center md:items-start gap-8">
				<div class="absolute top-0 right-0 w-64 h-64 bg-primary/20 rounded-full -translate-y-1/2 translate-x-1/2 blur-[60px]"></div>
				
				<div class="w-32 h-32 md:w-40 md:h-40 shrink-0 rounded-2xl bg-gradient-to-br from-primary to-[#9333EA] flex items-center justify-center shadow-lg relative z-10 shadow-primary/50">
					<span class="text-5xl font-display font-bold text-white">H</span>
				</div>
				
				<div class="text-center md:text-left relative z-10 flex-1">
					<h3 class="text-2xl lg:text-3xl font-bold text-white mb-2">Helio</h3>
					<div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-primary/20 text-primary-light text-xs font-semibold uppercase tracking-wider mb-5">
						Fundador da Growth Hub
					</div>
					<p class="text-text-muted leading-relaxed text-sm lg:text-base max-w-2xl">
						Especialista absoluto em IA aplicada a processos comerciais. Construiu a ponte perfeita entre a teoria da Inteligência Artificial e a prática das vendas automatizadas usando o n8n. Já ajudou centenas de profissionais a escalar resultados criando máquinas de vendas que operam 24/7.
					</p>
				</div>
			</div>
		</div>

	</div>

	<!-- Testimonials Marquee / Floating Bobbles -->
	<div class="w-full overflow-hidden flex flex-col gap-6 py-4 relative" data-animate="fade-in-up" style="animation-delay: 200ms">
		
		<!-- Left Fade / Right Fade -->
		<div class="absolute inset-y-0 left-0 w-32 bg-gradient-to-r from-background to-transparent z-10 pointer-events-none"></div>
		<div class="absolute inset-y-0 right-0 w-32 bg-gradient-to-l from-background to-transparent z-10 pointer-events-none"></div>

		<!-- Linha 1 -->
		<div class="flex flex-nowrap shrink-0 animate-marquee gap-6 w-max">
			{cases.map(c => (
				<div class="w-[350px] shrink-0 glass-card rounded-2xl p-6 border border-white/5 bg-surface/40 hover:bg-surface/60 transition-colors">
					<div class="flex gap-1 mb-4 text-warning">
						{[1,2,3,4,5].map(() => <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>)}
					</div>
					<p class="text-text-muted text-sm leading-relaxed mb-6">"{c.text || c.before + ' virou ' + c.after}"</p>
					<div class="flex items-center gap-3">
						<div class="w-8 h-8 rounded-full bg-primary/20 text-primary-light flex items-center justify-center text-xs font-bold">
							{(c.name || c.author || 'A').charAt(0)}
						</div>
						<div>
							<h4 class="text-white text-sm font-bold">{c.name || c.author}</h4>
							<p class="text-text-dark text-xs">{c.role || 'Membro do Automators'}</p>
						</div>
					</div>
				</div>
			))}
			<!-- Duplicate for infinite scroll -->
			{cases.map(c => (
				<div class="w-[350px] shrink-0 glass-card rounded-2xl p-6 border border-white/5 bg-surface/40 hover:bg-surface/60 transition-colors" aria-hidden="true">
					<div class="flex gap-1 mb-4 text-warning">
						{[1,2,3,4,5].map(() => <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>)}
					</div>
					<p class="text-text-muted text-sm leading-relaxed mb-6">"{c.text || c.before + ' virou ' + c.after}"</p>
					<div class="flex items-center gap-3">
						<div class="w-8 h-8 rounded-full bg-primary/20 text-primary-light flex items-center justify-center text-xs font-bold">
							{(c.name || c.author || 'A').charAt(0)}
						</div>
						<div>
							<h4 class="text-white text-sm font-bold">{c.name || c.author}</h4>
							<p class="text-text-dark text-xs">{c.role || 'Membro do Automators'}</p>
						</div>
					</div>
				</div>
			))}
		</div>

	</div>
</section>
