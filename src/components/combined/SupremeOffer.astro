---
import { SITE_CONFIG, formatPrice } from '../../config/site';
import CTAButton from '../CTAButton.astro';

const anchorION = SITE_CONFIG.anchorPriceION;
const anchorAutomators = SITE_CONFIG.anchorPriceAutomators;
const anchorTotal = SITE_CONFIG.anchorTotal;
const bundlePrice = SITE_CONFIG.bundlePrice;
const installments = SITE_CONFIG.installmentCount;
const installmentPrice = SITE_CONFIG.installmentPrice;

const faqs = [
	{ q: 'Preciso ter experiência com IA ou automação?', a: 'Não. O programa foi desenhado para levar você do zero à implementação. Começamos com os fundamentos.' },
	{ q: 'Quanto tempo preciso dedicar?', a: 'Sugerimos 3-4 horas por semana (1h de call ao vivo + 2-3h de prática).' },
	{ q: 'As calls ao vivo ficam gravadas?', a: 'Sim, e o acesso é vitalício na área de membros.' },
	{ q: 'Preciso saber programar?', a: 'Não. Focamos em no-code/low-code com n8n. Tudo é estruturado de forma visual.' },
	{ q: 'E se eu não gostar?', a: 'Você tem garantia integral de 7 dias com devolução 100% sem perguntas.' },
];
---

<section id="oferta" class="py-24 lg:py-32 scroll-mt-32 relative overflow-hidden bg-background">
	<!-- Glow Effects -->
	<div class="absolute bottom-0 right-0 w-[600px] h-[600px] bg-primary/20 rounded-full blur-[150px] pointer-events-none"></div>

	<div class="max-w-[1200px] mx-auto px-6 lg:px-8 relative z-10">
		<div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">
			
			<!-- COLUNA ESQUERDA: FAQs e Garantia (5 Colunas) -->
			<div class="lg:col-span-5 flex flex-col gap-8" data-animate="fade-in-up">
				<div>
					<span class="inline-block py-1 px-3 rounded-full border border-white/10 bg-surface-alt/50 text-xs text-text-muted font-semibold tracking-wider uppercase mb-4">
						DÚVIDAS FREQUENTES
					</span>
					<h2 class="text-3xl font-display font-bold text-white mb-6">Ainda com dúvidas?</h2>
					
					<div class="space-y-2">
						{faqs.map(faq => (
							<details class="group glass-card rounded-xl border border-white/5 bg-surface/30 p-4 transition-all open:bg-surface/50">
								<summary class="flex items-center justify-between cursor-pointer text-white font-semibold text-sm sm:text-base hover:text-primary-light transition-colors list-none [&::-webkit-details-marker]:hidden">
									<span class="pr-2">{faq.q}</span>
									<svg class="w-5 h-5 text-text-muted shrink-0 transition-transform duration-200 group-open:rotate-180" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
								</summary>
								<div class="pt-3 pb-1 text-sm text-text-muted leading-relaxed">
									{faq.a}
								</div>
							</details>
						))}
					</div>
				</div>

				<!-- Selo Garantia Menor -->
				<div class="glass-card rounded-2xl p-6 border border-success/20 bg-success/5 flex items-start gap-4" data-animate="fade-in-up" style="animation-delay: 150ms">
					<div class="w-12 h-12 shrink-0 rounded-full bg-success/20 text-success flex items-center justify-center">
						<svg class="w-6 h-6" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/><path d="m9 12 2 2 4-4"/></svg>
					</div>
					<div>
						<h3 class="text-white font-bold mb-1">Garantia Blindada de 7 Dias</h3>
						<p class="text-xs text-text-muted leading-relaxed text-balance">Risco zero. Acesse as primeiras aulas e ferramentas. Se achar que não serve pro seu momento, devolvemos 100%.</p>
					</div>
				</div>
			</div>

			<!-- COLUNA DIREITA: Pricing Gigante (7 Colunas) -->
			<div class="lg:col-span-7" data-animate="slide-in-right">
				<div class="glass-card border-2 border-primary/50 shadow-[0_0_50px_rgba(124,58,237,0.2)] rounded-3xl p-8 lg:p-12 relative overflow-hidden h-full flex flex-col justify-center">
					<!-- Borda Neon Topo -->
					<div class="absolute top-0 left-0 right-0 h-1.5 bg-gradient-to-r from-primary to-[#9333EA] shadow-[0_0_20px_rgba(124,58,237,0.8)]"></div>
					<div class="absolute top-0 right-0 w-64 h-64 bg-primary/20 rounded-full blur-[80px]"></div>

					<div class="relative z-10 text-center">
						<div class="inline-flex justify-center items-center gap-2 px-4 py-1.5 rounded-full bg-warning/20 border border-warning/30 text-warning text-xs font-bold uppercase tracking-wider mb-8 mx-auto">
							<span class="w-2 h-2 rounded-full bg-warning animate-ping"></span>
							VAGAS LIMITADAS – TURMA INAUGURAL
						</div>

						<h2 class="text-3xl md:text-5xl font-display font-bold text-white mb-4">
							A sua máquina de vendas <br/>começa <span class="text-primary-light">agora.</span>
						</h2>

						<!-- Ancoragem -->
						<div class="w-full max-w-sm mx-auto p-4 rounded-xl bg-surface/50 border border-white/5 mb-8">
							<p class="text-xs text-text-muted uppercase tracking-wider font-semibold mb-3">Valor dos programas separados</p>
							<div class="flex justify-between items-center text-sm text-text-muted mb-2">
								<span>Treinamento ION</span>
								<span class="line-through">{formatPrice(anchorION)}</span>
							</div>
							<div class="flex justify-between items-center text-sm text-text-muted mb-3 border-b border-white/5 pb-3">
								<span>Automators Club</span>
								<span class="line-through">{formatPrice(anchorAutomators)}</span>
							</div>
							<div class="flex justify-between items-center font-bold text-white">
								<span>Total Isolado</span>
								<span class="line-through text-error">{formatPrice(anchorTotal)}</span>
							</div>
						</div>

						<!-- Preço Final -->
						<p class="text-text-muted font-medium mb-2">Bundle Completo: ION + Automators</p>
						<div class="mb-8">
							{bundlePrice > 0 ? (
								<>
									<div class="text-6xl md:text-7xl font-display font-bold text-white drop-shadow-md mb-2">{formatPrice(bundlePrice)}</div>
									{installmentPrice > 0 && <p class="text-text-muted text-lg">ou {installments}x de <strong class="text-white">{formatPrice(installmentPrice)}</strong></p>}
								</>
							) : (
								<p class="text-4xl lg:text-5xl font-display font-bold text-white mb-2">Consulte o valor</p>
							)}
						</div>

						<!-- CTA -->
						<CTAButton size="lg" class="w-full sm:w-auto min-w-[300px]" id="pricing-cta">
							Garantir Vaga no Bundle
							<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
						</CTAButton>

						<p class="text-text-dark text-xs mt-5 flex justify-center items-center gap-2">
							<svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
							Pagamento Seguro • Acesso Imediato à Plataforma
						</p>
					</div>

				</div>
			</div>

		</div>
	</div>
</section>
