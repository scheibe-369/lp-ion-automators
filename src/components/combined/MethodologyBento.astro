---
import SectionHeadline from '../SectionHeadline.astro';
import Countdown from '../Countdown.astro';

const steps = [
	{ number: '1', title: 'Acesso Imediato', desc: 'Plataforma e material preparatório.' },
	{ number: '2', title: 'Semana 0', desc: 'Setup de n8n e APIs.' },
	{ number: '3', title: '8 Semanas Vivo', desc: 'Aulas e projetos reais.' },
	{ number: '4', title: 'Escala', desc: 'Automações em produção.' },
];

const modules = [
	'IA no Funil de Vendas Completo',
	'Prospecção Automática com n8n',
	'Scripts Hiper-personalizados de IA',
	'n8n do Zero ao Deploy em Produção',
	'Integrações via WhatsApp & CRM',
];

const differentials = [
	{ title: '8 Semanas Ao Vivo', icon: 'M15.536 11.293a1 1 0 0 0 0 1.414l2.376 2.377a1 1 0 0 0 1.414 0l2.377-2.377...' }, // Simplified for brevity, will use SVGs below
	{ title: 'Suporte a Projetos', icon: 'M21 15v4a2 2 0 0 1-2 2H5...' },
	{ title: 'Acesso Vitalício', icon: 'M12 22A10 10 0 1 0 12 2...' }
];
---

<section id="metodologia" class="py-20 lg:py-32 scroll-mt-32 relative">
	<div class="max-w-[1200px] mx-auto px-6 lg:px-8">
		
		<div class="text-center mb-16" data-animate="fade-in-up">
			<span class="inline-block py-1 px-3 rounded-full bg-primary/20 border border-primary/30 text-xs text-primary-light font-semibold tracking-wider uppercase mb-4 shadow-[0_0_15px_rgba(124,58,237,0.3)]">
				A METODOLOGIA
			</span>
			<h2 class="text-3xl md:text-5xl font-display font-bold text-white leading-tight">
				Sua jornada pra dominar <br/>o jogo <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary-light to-primary">das automações</span>
			</h2>
		</div>

		<!-- Bento Grid -->
		<div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8">
			
			<!-- Card 1: A Jornada (2 Colunas Wide Desktop) -->
			<div class="md:col-span-2 glass-card rounded-2xl p-8 border border-white/5 bg-gradient-to-br from-surface to-surface-alt/50 relative overflow-hidden" data-animate="fade-in-up">
				<div class="absolute top-0 right-0 w-[400px] h-[400px] bg-primary/10 rounded-full blur-[80px] pointer-events-none"></div>
				
				<h3 class="text-2xl font-bold text-white mb-8 flex items-center gap-3 relative z-10">
					<svg class="w-6 h-6 text-primary-light" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
					Jornada de Implementação
				</h3>

				<div class="grid grid-cols-1 sm:grid-cols-4 gap-6 relative z-10">
					<div class="hidden sm:block absolute top-6 left-[10%] right-[10%] h-0.5 border-t-2 border-dashed border-white/10"></div>
					{steps.map((s) => (
						<div class="flex flex-col items-start sm:items-center text-left sm:text-center relative">
							<div class="w-12 h-12 rounded-full bg-surface-alt border-2 border-primary/30 text-white font-bold flex items-center justify-center mb-4 z-10 shadow-[0_0_15px_rgba(124,58,237,0.2)]">
								{s.number}
							</div>
							<h4 class="text-sm font-bold text-white mb-2">{s.title}</h4>
							<p class="text-xs text-text-muted">{s.desc}</p>
						</div>
					))}
				</div>
			</div>

			<!-- Card 2: Diferenciais / Extras (1 Coluna) -->
			<div class="md:col-span-1 glass-card rounded-2xl p-8 border border-primary/20 bg-primary/5 flex flex-col justify-center" data-animate="fade-in-up" style="animation-delay: 150ms">
				<h3 class="text-lg font-bold text-white mb-6 border-b border-primary/20 pb-4">O que só essa turma tem</h3>
				
				<ul class="space-y-6">
					<li class="flex gap-4 items-start">
						<div class="text-primary-light shrink-0">
							<svg class="w-6 h-6" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
						</div>
						<div>
							<h4 class="text-white text-sm font-bold">Calls ao Vivo</h4>
							<p class="text-xs text-text-muted mt-1">Crie junto com nossos mestres e acelere.</p>
						</div>
					</li>
					<li class="flex gap-4 items-start">
						<div class="text-primary-light shrink-0">
							<svg class="w-6 h-6" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
						</div>
						<div>
							<h4 class="text-white text-sm font-bold">Comunidade</h4>
							<p class="text-xs text-text-muted mt-1">Networking e projetos reais com outros founders.</p>
						</div>
					</li>
					<li class="flex gap-4 items-start">
						<div class="text-primary-light shrink-0">
							<svg class="w-6 h-6" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
						</div>
						<div>
							<h4 class="text-white text-sm font-bold">Para Sempre</h4>
							<p class="text-xs text-text-muted mt-1">Acesso vitalício aos materiais e gravações.</p>
						</div>
					</li>
				</ul>
			</div>

			<!-- Card 3: Ementa/Módulos Slim (2 colunas) -->
			<div class="md:col-span-2 glass-card rounded-2xl p-8 border border-white/5" data-animate="fade-in-up" style="animation-delay: 200ms">
				<h3 class="text-xl font-bold text-white mb-6">Conteúdo Direto ao Ponto</h3>
				<div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
					{modules.map(mod => (
						<div class="flex items-center gap-3 p-3 rounded-lg bg-surface/50 border border-white/5 hover:border-primary/30 transition-colors">
							<svg class="w-5 h-5 text-success shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
							<span class="text-sm text-text-muted font-medium">{mod}</span>
						</div>
					))}
					<div class="flex items-center justify-center gap-3 p-3 rounded-lg bg-surface-alt/50 border border-white/5 cursor-pointer hover:bg-white/5 transition-colors group">
						<span class="text-sm text-primary-light font-semibold group-hover:text-primary transition-colors">+ Ver Ementa Completa</span>
					</div>
				</div>
			</div>

			<!-- Card 4: Urgência e Contador (1 coluna) -->
			<div class="md:col-span-1 glass-card rounded-2xl p-8 border border-warning/30 bg-warning/5 flex flex-col items-center justify-center text-center relative overflow-hidden" data-animate="fade-in-up" style="animation-delay: 300ms">
				<div class="absolute inset-0 bg-warning/10 animate-pulse-slow"></div>
				<div class="relative z-10 w-full flex flex-col items-center">
					<svg class="w-8 h-8 text-warning mb-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
					<h3 class="text-warning font-bold mb-4 uppercase tracking-wider text-sm">Inscrições Encerram Em:</h3>
					<div class="w-full">
						<Countdown />
					</div>
				</div>
			</div>

		</div>
	</div>
</section>
