---
import SectionHeadline from '../SectionHeadline.astro';

const steps = [
	{ number: '1', title: 'Acesso Imediato', desc: 'Plataforma e material preparatório.' },
	{ number: '2', title: 'Semana 0', desc: 'Setup de n8n, Antigravity, Claude Code e APIs.' },
	{ number: '3', title: '8 Semanas Ao Vivo', desc: 'Aulas e construção de projetos juntos dos alunos' },
	{ number: '4', title: 'Produção', desc: 'Acompanhamento dos projetos dos alunos.' },
];
---

<section id="metodologia" class="py-24 lg:py-32 scroll-mt-32 relative">
	<div class="max-w-[1200px] mx-auto px-6 lg:px-8">
		
		<!-- Bento Grid -->
		<div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8">
			
			<!-- Card 1 Wrapper for Sticky Scroll (Title + Card) -->
			<div id="jornada-scroll-wrapper" class="md:col-span-3 h-[400vh] relative mb-12">
				<!-- Unified Sticky Container -->
				<div id="jornada-sticky-card" class="sticky top-[25vh] z-20 flex flex-col gap-6 lg:gap-8" data-animate="fade-in-up">
					
					<!-- Hero Methodology Title -->
					<div class="text-center">
						<h2 class="text-3xl md:text-5xl font-display font-bold text-white leading-tight">
							Sua Jornada pra Dominar <br/>o Jogo <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary-light to-primary">das Automações</span>
						</h2>
					</div>

					<!-- Glass Card Original -->
					<div class="glass-card rounded-2xl p-8 border border-white/5 bg-gradient-to-br from-surface to-surface-alt/50 overflow-hidden relative">
						<div class="absolute top-0 right-0 w-[400px] h-[400px] bg-primary/10 rounded-full blur-[80px] pointer-events-none"></div>
						
						<h3 class="text-2xl font-bold text-white mb-8 flex items-center gap-3 relative z-10">
							<svg class="w-6 h-6 text-primary-light" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
							Jornada de Implementação
						</h3>

					<div class="grid grid-cols-1 sm:grid-cols-4 gap-6 relative z-10">
						<!-- Progress Line Segments Container -->
						<div class="hidden sm:flex absolute top-6 left-[12.5%] right-[12.5%] items-center justify-between pointer-events-none" style="width: 75%; z-index: 1;">
							<div class="jornada-segment flex-1 h-[3px] bg-white/10 relative overflow-hidden mx-[24px]">
								<div class="jornada-segment-fill absolute left-0 top-0 bottom-0 bg-primary shadow-[0_0_15px_rgba(168,85,247,0.5)]" style="width: 0%; transition: none;"></div>
							</div>
							<div class="jornada-segment flex-1 h-[3px] bg-white/10 relative overflow-hidden mx-[24px]">
								<div class="jornada-segment-fill absolute left-0 top-0 bottom-0 bg-primary shadow-[0_0_15px_rgba(168,85,247,0.5)]" style="width: 0%; transition: none;"></div>
							</div>
							<div class="jornada-segment flex-1 h-[3px] bg-white/10 relative overflow-hidden mx-[24px]">
								<div class="jornada-segment-fill absolute left-0 top-0 bottom-0 bg-primary shadow-[0_0_15px_rgba(168,85,247,0.5)]" style="width: 0%; transition: none;"></div>
							</div>
						</div>
						
						{steps.map((s, idx) => (
							<div class="jornada-step flex flex-col items-start sm:items-center text-left sm:text-center relative transition-all duration-300" data-index={idx}>
								<div class="jornada-circle w-12 h-12 rounded-full bg-surface border-2 text-white font-bold flex items-center justify-center mb-4 z-10 transition-all duration-300 shadow-xl">
									{s.number}
								</div>
								<h4 class="text-sm font-bold text-white mb-2">{s.title}</h4>
								<p class="text-xs text-text-muted">{s.desc}</p>
							</div>
						))}
					</div>
				</div>
			</div>
		</div>
	</div>
</section>

<style is:global>
	.jornada-step {
		opacity: 0.3;
		filter: grayscale(100%);
	}
	.jornada-step.active {
		opacity: 1;
		filter: grayscale(0%);
	}
	.jornada-circle {
		border-color: rgba(255, 255, 255, 0.1) !important;
		background-color: #0B0F1A !important; /* Solid background to mask line */
		color: #94a3b8 !important;
		box-shadow: none !important;
	}
	.jornada-step.active .jornada-circle {
		border-color: rgba(168, 85, 247, 0.8) !important;
		background-color: rgba(168, 85, 247, 0.2) !important;
		color: white !important;
		box-shadow: 0 0 25px rgba(168, 85, 247, 0.4) !important;
	}
	.jornada-segment-fill {
		background-color: #a855f7 !important;
	}
</style>

<script>
	function initScrollytelling() {
		const wrapper = document.getElementById('jornada-scroll-wrapper');
		const card = document.getElementById('jornada-sticky-card');
		const steps = document.querySelectorAll('.jornada-step');
		const fills = document.querySelectorAll('.jornada-segment-fill');
		
		if (!wrapper || !card || steps.length === 0) return;

		let targetProgress = 0;
		let currentProgress = 0;
		const LERP_FACTOR = 0.08; // Control softness

		const calculateProgress = () => {
			const wrapperRect = wrapper.getBoundingClientRect();
			const computedTopVal = window.getComputedStyle(card).top;
			const topOffset = parseInt(computedTopVal, 10) || 0; 
			
			const scrollableDistance = wrapper.offsetHeight - card.offsetHeight;
			const scrolled = topOffset - wrapperRect.top;
			
			if (wrapperRect.top > topOffset) return 0;
			if (scrolled >= scrollableDistance) return 1;
			return scrolled / scrollableDistance;
		};

		const animate = () => {
			// LERP logic for progressive smoothness
			currentProgress += (targetProgress - currentProgress) * LERP_FACTOR;

			// Update Fills
			fills.forEach((fill, i) => {
				const segmentStart = i * (1/3);
				let segmentProgress = 0;
				if (currentProgress > segmentStart) {
					segmentProgress = Math.min(1, (currentProgress - segmentStart) / (1/3));
				}
				if (fill instanceof HTMLElement) {
					fill.style.width = `${segmentProgress * 100}%`;
				}
			});
			
			// Update Steps
			const thresholds = [0, 0.3, 0.6, 0.9];
			steps.forEach((step, index) => {
				if (currentProgress >= thresholds[index]) {
					step.classList.add('active');
				} else {
					step.classList.remove('active');
				}
			});

			if (Math.abs(targetProgress - currentProgress) > 0.0001) {
				requestAnimationFrame(animate);
			}
		};

		window.addEventListener('scroll', () => {
			const newTarget = calculateProgress();
			if (newTarget !== targetProgress) {
				const isAnimationIdle = Math.abs(targetProgress - currentProgress) < 0.0001;
				targetProgress = newTarget;
				if (isAnimationIdle) requestAnimationFrame(animate);
			}
		});

		// Start
		targetProgress = calculateProgress();
		currentProgress = targetProgress;
		animate();
	}

	document.addEventListener('DOMContentLoaded', initScrollytelling);
	if (document.readyState === 'complete' || document.readyState === 'interactive') {
		initScrollytelling();
	}
</script>
