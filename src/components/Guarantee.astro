<section id="garantia" class="py-24 lg:py-32 scroll-mt-20">
	<div class="max-w-[800px] mx-auto px-6 lg:px-8">
		<div class="glass-card rounded-2xl p-8 lg:p-12 text-center" data-animate="scale-in">
			<div class="w-20 h-20 rounded-full glass-card border-success/20 text-success shadow-[0_0_30px_rgba(34,197,94,0.15)] flex items-center justify-center mx-auto mb-6">
				<svg class="w-10 h-10" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/><path d="m9 12 2 2 4-4"/></svg>
			</div>
			<h2 class="text-2xl lg:text-3xl font-display font-bold text-white mb-4">Garantia incondicional de 7 dias</h2>
