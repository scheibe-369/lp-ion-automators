---
import { SITE_CONFIG } from '../config/site';
import CTAButton from './CTAButton.astro';
import Marquee from './Marquee.astro';
---

<section id="hero" class="relative min-h-screen flex items-center justify-center pt-16 overflow-hidden bg-background">
	<!-- Background glow effect -->
	<div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-primary/20 rounded-full blur-[120px] pointer-events-none animate-glow-pulse"></div>
	
	<div class="relative max-w-[1200px] mx-auto px-6 lg:px-8 text-center py-20 lg:py-32">
		<!-- Badge urgência -->
		<div class="inline-flex items-center gap-2 px-5 py-2 rounded-full glass-card border-primary/30 text-primary-light text-xs font-semibold tracking-wider uppercase mb-8 shadow-[0_0_20px_rgba(124,58,237,0.2)]" data-animate="fade-in">
			<span class="relative flex h-2 w-2">
				<span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-warning opacity-75"></span>
				<span class="relative inline-flex rounded-full h-2 w-2 bg-warning shadow-[0_0_10px_rgba(234,179,8,0.8)]"></span>
			</span>
			Turma Inaugural — Vagas Limitadas
		</div>
		
		<!-- Headline -->
		<h1 class="text-4xl sm:text-5xl lg:text-7xl font-display font-bold leading-[1.1] mb-6 text-white max-w-5xl mx-auto" data-animate="fade-in-up">
			Domine o <span class="text-primary-light">Vibe coding</span> e <span class="text-primary-light">automações com n8n</span> em 8 semanas
		</h1>
		
		<!-- Subheadline -->
		<p class="text-lg sm:text-xl text-text-muted max-w-2xl mx-auto mb-10 leading-relaxed" data-animate="fade-in-up">
			Calls ao vivo toda semana, suporte a projetos reais, grupo fechado e acesso vitalício ao que for gravado.
		</p>
		
		<!-- CTA -->
		<div class="flex flex-col sm:flex-row gap-4 justify-center mb-8" data-animate="fade-in-up">
			<CTAButton size="lg" id="hero-cta">
				Garantir minha vaga na turma inaugural
				<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
			</CTAButton>
		</div>
		
		<!-- Prova social -->
		<div class="flex items-center justify-center gap-4 text-text-muted text-sm mt-8 group select-none cursor-pointer" data-animate="fade-in">
			<div class="flex items-center -space-x-5">
				<img src="/images/avatars/avatar-1.png" alt="Membro" class="avatar-stack w-10 h-10 rounded-full border-2 border-background object-cover shadow-2xl z-[6]" style="--i:0" />
				<img src="/images/avatars/avatar-2.jpg" alt="Membro" class="avatar-stack w-10 h-10 rounded-full border-2 border-background object-cover shadow-2xl z-[5]" style="--i:1" />
				<img src="/images/avatars/avatar-3.png" alt="Membro" class="avatar-stack w-10 h-10 rounded-full border-2 border-background object-cover shadow-2xl z-[4]" style="--i:2" />
				<img src="/images/avatars/avatar-4.jpg" alt="Membro" class="avatar-stack w-10 h-10 rounded-full border-2 border-background object-cover shadow-2xl z-[3]" style="--i:3" />
				<img src="/images/avatars/avatar-5.png" alt="Membro" class="avatar-stack w-10 h-10 rounded-full border-2 border-background object-cover shadow-2xl z-[2]" style="--i:4" />
				<img src="/images/avatars/avatar-6.jpg" alt="Membro" class="avatar-stack w-10 h-10 rounded-full border-2 border-background object-cover shadow-2xl z-[1]" style="--i:5" />
			</div>
			<div class="flex flex-col items-start leading-none text-left">
				<div class="text-white font-bold text-base">+ 100 ALUNOS</div>
				<div class="text-[10px] tracking-[0.2em] uppercase opacity-70 font-medium">Impactados pela nossa comunidade</div>
			</div>
		</div>
	</div>

	<!-- Marquee Integrado / Glassmorphism -->
	<div class="absolute bottom-0 left-0 w-full z-10">
		<Marquee />
	</div>
</section>

<style>
	.avatar-stack {
		/* Transição suave apenas de posição e cor */
		transition: transform 0.3s ease-out, border-color 0.3s ease;
		will-change: transform;
	}

	/* Interatividade sem expansão de tamanho */
	.avatar-stack:hover {
		transform: translateY(-5px);
		z-index: 100 !important;
		border-color: #7c3aed !important;
		box-shadow: 0 10px 20px rgba(124, 58, 237, 0.3);
	}
</style>
