---
import { SITE_CONFIG } from '../config/site';
---

<section id="contato" class="py-24 lg:py-32 scroll-mt-20 bg-surface/50">
	<div class="max-w-[600px] mx-auto px-6 lg:px-8 text-center">
		<span class="inline-block text-xs font-semibold tracking-wider uppercase text-primary-light bg-primary/10 border border-primary/20 px-4 py-1.5 rounded-full mb-5">FALE CONOSCO</span>
		<h2 class="text-2xl lg:text-3xl font-display font-bold text-white mb-4" data-animate="fade-in-up">Ainda tem dúvidas?</h2>
		<p class="text-text-muted mb-8 leading-relaxed" data-animate="fade-in-up">Envie uma mensagem direta para nosso WhatsApp. Responderemos o mais rápido possível.</p>

		<form id="whatsapp-form" class="space-y-4 text-left" data-animate="fade-in-up">
			<div>
				<label for="wa-name" class="block text-sm font-medium text-text-muted mb-1.5">Seu nome</label>
				<input 
					type="text"
					id="wa-name"
					name="name"
					maxlength="100"
					required
					placeholder="Como podemos te chamar?"
					class="w-full bg-surface border border-border rounded-lg px-4 py-3 text-text placeholder:text-text-dark focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary/50 transition-colors"
				/>
			</div>
			<div>
				<label for="wa-message" class="block text-sm font-medium text-text-muted mb-1.5">Mensagem <span class="text-text-dark">(opcional)</span></label>
				<textarea 
					id="wa-message"
					name="message"
					rows="3"
					maxlength="500"
					placeholder="Conte sua dúvida..."
					class="w-full bg-surface border border-border rounded-lg px-4 py-3 text-text placeholder:text-text-dark focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary/50 transition-colors resize-none"
				></textarea>
			</div>
			<button 
				type="submit"
				class="w-full bg-[#25D366] text-white font-semibold py-3.5 rounded-full hover:bg-[#20BD5A] active:scale-[0.98] transition-all duration-200 flex items-center justify-center gap-2"
			>
				<svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
				Enviar pelo WhatsApp
			</button>
		</form>
	</div>
</section>

<script define:vars={{ whatsappNumber: SITE_CONFIG.whatsappNumber }}>
	document.getElementById('whatsapp-form')?.addEventListener('submit', (e) => {
		e.preventDefault();
		const form = e.target;
		const name = form.querySelector('#wa-name')?.value?.trim().replace(/<[^>]*>/g, '').slice(0, 100) || '';
		const message = form.querySelector('#wa-message')?.value?.trim().replace(/<[^>]*>/g, '').slice(0, 500) || '';
		
		let text = `Olá! Meu nome é ${name}.`;
		if (message) text += ` ${message}`;
		
		const url = `https://wa.me/${whatsappNumber}?text=${encodeURIComponent(text)}`;
		window.location.href = url;
	});
</script>
