---
import SectionHeadline from './SectionHeadline.astro';

const cards = [
	{
		icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m15 9-6 6"/><path d="m9 9 6 6"/></svg>`,
		title: 'Ferramentas que não conversam entre si',
		description: 'Você gasta horas conectando planilhas, CRMs e canais de atendimento manualmente. Cada integração quebra e ninguém sabe consertar.',
	},
	{
		icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 8V4H8"/><rect width="16" height="12" x="4" y="8" rx="2"/><path d="M2 14h2"/><path d="M20 14h2"/><path d="M15 13v2"/><path d="M9 13v2"/></svg>`,
		title: 'IA que parece promessa, não prática',
		description: 'Você ouve sobre ChatGPT todo dia, mas não sabe como aplicar nos seus processos comerciais de forma que realmente gere receita.',
	},
	{
		icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10 10h4"/><path d="M19 7V4a1 1 0 0 0-1-1H5a2 2 0 0 0 0 4h15a1 1 0 0 1 1 1v4h-3a2 2 0 0 0 0 4h3a1 1 0 0 0 1-1v-2.5"/><path d="M3 5v14a2 2 0 0 0 2 2h15a1 1 0 0 0 1-1v-4"/></svg>`,
		title: 'Dinheiro deixado na mesa todo mês',
		description: 'Leads esfriam, follow-ups não acontecem, propostas atrasam. O processo comercial funciona no braço e você perde vendas por falta de automação.',
	},
];
---

<section id="problema" class="py-24 lg:py-32 scroll-mt-20">
	<div class="max-w-[1200px] mx-auto px-6 lg:px-8">
		<SectionHeadline
			badge="O PROBLEMA"
			title="Você sabe que precisa de IA e automação.<br/><span class='text-primary-light'>Mas não sabe por onde começar.</span>"
			subtitle="A maioria dos profissionais enfrenta os mesmos 3 bloqueios que impedem de escalar seus resultados comerciais."
		/>

		<div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8">
			{cards.map((card, i) => (
				<div 
					class="group glass-card rounded-xl p-8"
					data-animate="fade-in-up"
					style={`animation-delay: ${i * 100}ms`}
				>
					<div class="w-12 h-12 rounded-xl bg-error/10 text-error flex items-center justify-center mb-5">
						<Fragment set:html={card.icon} />
					</div>
					<h3 class="text-lg font-semibold text-white mb-3">{card.title}</h3>
					<p class="text-text-muted leading-relaxed">{card.description}</p>
				</div>
			))}
		</div>
	</div>
</section>
