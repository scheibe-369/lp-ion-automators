---
const targetDate = new Date("2026-05-07T23:59:59-03:00").getTime();
---

<div class="flex items-center justify-center gap-2 sm:gap-3" id="countdown-wrapper">
	<!-- Dias -->
	<div class="flex flex-col items-center min-w-[60px] sm:min-w-[70px]">
		<div class="w-full bg-black/40 backdrop-blur-md border border-white/10 rounded-xl py-3 px-2 mb-1.5 shadow-lg shadow-black/20">
			<span class="text-3xl sm:text-4xl font-display font-bold text-white countdown-days leading-none">00</span>
		</div>
		<span class="text-[9px] sm:text-[10px] font-bold tracking-[0.1em] uppercase text-warning opacity-70">dias</span>
	</div>
	
	<span class="text-warning/30 text-xl font-bold mb-6">:</span>
	
	<!-- Horas -->
	<div class="flex flex-col items-center min-w-[60px] sm:min-w-[70px]">
		<div class="w-full bg-black/40 backdrop-blur-md border border-white/10 rounded-xl py-3 px-2 mb-1.5 shadow-lg shadow-black/20">
			<span class="text-3xl sm:text-4xl font-display font-bold text-white countdown-hours leading-none">00</span>
		</div>
		<span class="text-[9px] sm:text-[10px] font-bold tracking-[0.1em] uppercase text-warning opacity-70">horas</span>
	</div>
	
	<span class="text-warning/30 text-xl font-bold mb-6">:</span>
	
	<!-- Min -->
	<div class="flex flex-col items-center min-w-[60px] sm:min-w-[70px]">
		<div class="w-full bg-black/40 backdrop-blur-md border border-white/10 rounded-xl py-3 px-2 mb-1.5 shadow-lg shadow-black/20">
			<span class="text-3xl sm:text-4xl font-display font-bold text-white countdown-mins leading-none">00</span>
		</div>
		<span class="text-[9px] sm:text-[10px] font-bold tracking-[0.1em] uppercase text-warning opacity-70">min</span>
	</div>
	
	<span class="text-warning/30 text-xl font-bold mb-6">:</span>
	
	<!-- Seg -->
	<div class="flex flex-col items-center min-w-[60px] sm:min-w-[70px]">
		<div class="w-full bg-black/40 border border-warning/20 rounded-xl py-3 px-2 mb-1.5 shadow-lg shadow-warning/5 animate-pulse-slow">
			<span class="text-3xl sm:text-4xl font-display font-bold text-white countdown-secs leading-none">00</span>
		</div>
		<span class="text-[9px] sm:text-[10px] font-bold tracking-[0.1em] uppercase text-warning opacity-70">seg</span>
	</div>
</div>

<script define:vars={{ targetDate }}>
	function updateCountdown() {
		const now = Date.now();
		const diff = targetDate - now;

		if (diff <= 0) {
			document.querySelectorAll('.countdown-days, .countdown-hours, .countdown-mins, .countdown-secs').forEach(el => el.textContent = '00');
			const wrapper = document.getElementById('countdown-wrapper');
			if (wrapper) {
				const expired = document.createElement('p');
				expired.className = 'text-error font-semibold text-lg';
				expired.textContent = 'Inscrições encerradas';
				wrapper.replaceWith(expired);
			}
			return;
		}

		const days = Math.floor(diff / (1000 * 60 * 60 * 24));
		const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
		const mins = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
		const secs = Math.floor((diff % (1000 * 60)) / 1000);

		document.querySelectorAll('.countdown-days').forEach(el => el.textContent = String(days).padStart(2, '0'));
		document.querySelectorAll('.countdown-hours').forEach(el => el.textContent = String(hours).padStart(2, '0'));
		document.querySelectorAll('.countdown-mins').forEach(el => el.textContent = String(mins).padStart(2, '0'));
		document.querySelectorAll('.countdown-secs').forEach(el => el.textContent = String(secs).padStart(2, '0'));

		setTimeout(updateCountdown, 1000 - (Date.now() % 1000));
	}

	updateCountdown();
</script>
