---
import { SITE_CONFIG } from '../config/site';

interface Props {
	href?: string;
	variant?: 'primary' | 'secondary' | 'ghost';
	size?: 'sm' | 'md' | 'lg';
	class?: string;
	id?: string;
}

const { 
	href = SITE_CONFIG.checkoutURL, 
	variant = 'primary', 
	size = 'md',
	class: className = '',
	id,
} = Astro.props;

const baseStyles = 'inline-flex items-center justify-center gap-2 font-semibold rounded-full min-h-[44px] cursor-pointer touch-manipulation z-10 relative';

const variants = {
	primary: 'bg-primary text-white btn-glow',
	secondary: 'bg-surface/50 border border-white/10 text-text shadow-sm backdrop-blur-md transition-all duration-200 hover:bg-surface/80 hover:border-white/20 hover:scale-[1.02] active:scale-[0.98]',
	ghost: 'bg-transparent text-text transition-all duration-200 hover:bg-white/5 active:scale-[0.98]',
};

const sizes = {
	sm: 'text-sm px-5 py-2',
	md: 'text-base px-7 py-3',
	lg: 'text-lg px-9 py-4',
};
---

<a 
	href={href}
	id={id}
	class:list={[baseStyles, variants[variant], sizes[size], className]}
>
	<slot />
</a>
